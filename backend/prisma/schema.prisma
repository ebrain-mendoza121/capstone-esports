generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("PRISMA_DATABASE_URL")
}

model alembic_version {
  version_num String @id(map: "alembic_version_pkc") @db.VarChar(32)

  @@ignore
}

model derived_metrics {
  id                 Int     @id @default(autoincrement())
  match_id           String  @db.VarChar
  puuid              String  @db.VarChar
  kda                Float?
  cs_per_min         Float?
  gold_per_min       Float?
  kill_participation Float?
  damage_share       Float?
  vision_per_min     Float?
  matches            matches @relation(fields: [match_id], references: [match_id], onDelete: Cascade, onUpdate: NoAction)
  players            players @relation(fields: [puuid], references: [puuid], onDelete: Cascade, onUpdate: NoAction)

  @@unique([match_id, puuid], map: "uq_derived_metrics_match_puuid")
  @@index([match_id], map: "ix_derived_metrics_match_id")
  @@index([puuid], map: "ix_derived_metrics_puuid")
}

model matches {
  match_id              String              @id @db.VarChar(64)
  game_creation         BigInt
  game_duration         Int
  queue_id              Int
  patch_version         String?             @db.VarChar(32)
  // Extended match metadata
  game_mode             String?             @db.VarChar(32)
  game_type             String?             @db.VarChar(32)
  platform_id           String?             @db.VarChar(16)
  game_start_timestamp  BigInt?
  game_end_timestamp    BigInt?
  end_of_game_result    String?             @db.VarChar(64)
  created_at            DateTime            @default(now()) @db.Timestamptz(6)
  derived_metrics       derived_metrics[]
  participant_stats     participant_stats[]
  team_objectives       team_objectives[]
  team_bans             team_bans[]
  match_timelines       match_timelines?
  draft_actions         draft_actions[]
  participant_perks     participant_perks[]

  @@index([game_creation], map: "ix_matches_game_creation")
  @@index([queue_id], map: "ix_matches_queue_id")
  @@index([platform_id], map: "ix_matches_platform_id")
}

model team_bans {
  id          Int     @id @default(autoincrement())
  match_id    String  @db.VarChar(64)
  team_id     Int
  champion_id Int
  pick_turn   Int
  matches     matches @relation(fields: [match_id], references: [match_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([match_id], map: "ix_team_bans_match_id")
  @@index([champion_id], map: "ix_team_bans_champion_id")
  @@index([match_id, team_id], map: "ix_team_bans_match_team")
}

model participant_stats {
  id           Int      @id @default(autoincrement())
  match_id     String   @db.VarChar(64)
  player_id    Int
  team_id      Int
  // Champion identity
  champion     String?  @db.VarChar(64)
  champion_id  Int?
  champ_level  Int?
  role         String?  @db.VarChar(32)
  // Core KDA
  kills        Int
  deaths       Int
  assists      Int
  double_kills Int?
  triple_kills Int?
  quadra_kills Int?
  penta_kills  Int?
  // Economy
  gold_earned              Int
  gold_spent               Int?
  // CS
  cs                       Int
  total_minions_killed     Int?
  neutral_minions_killed   Int?
  // Damage
  total_damage                   Int
  physical_damage_to_champions   Int?
  magic_damage_to_champions      Int?
  true_damage_to_champions       Int?
  total_damage_taken             Int?
  // Vision
  vision_score             Int
  wards_placed             Int?
  wards_killed             Int?
  detector_wards_placed    Int?
  // CC
  time_ccing_others        Int?
  // First objectives
  first_blood_kill         Boolean?
  first_blood_assist       Boolean?
  first_tower_kill         Boolean?
  first_tower_assist       Boolean?
  // Items
  item0   Int?
  item1   Int?
  item2   Int?
  item3   Int?
  item4   Int?
  item5   Int?
  item6   Int?
  // Summoner spells
  summoner1_id Int?
  summoner2_id Int?
  win          Boolean?
  matches      matches  @relation(fields: [match_id], references: [match_id], onDelete: Cascade, onUpdate: NoAction)
  players      players  @relation(fields: [player_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([champion], map: "ix_participant_stats_champion")
  @@index([champion_id], map: "ix_participant_stats_champion_id")
  @@index([match_id], map: "ix_participant_stats_match_id")
  @@index([player_id], map: "ix_participant_stats_player_id")
}

model players {
  id                Int                 @id @default(autoincrement())
  riot_id           String              @db.VarChar(64)
  tag_line          String              @db.VarChar(16)
  puuid             String              @unique(map: "ix_players_puuid") @db.VarChar(128)
  region            String              @db.VarChar(16)
  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  derived_metrics   derived_metrics[]
  participant_stats participant_stats[]
  participant_perks participant_perks[]
}

model team_objectives {
  id               Int      @id @default(autoincrement())
  match_id         String   @db.VarChar(64)
  team_id          Int
  win_flag         Boolean
  towers           Int
  tower_first      Boolean?
  dragons          Int
  dragon_first     Boolean?
  barons           Int
  baron_first      Boolean?
  rift_herald_kills  Int?
  rift_herald_first  Boolean?
  inhibitor_kills    Int?
  inhibitor_first    Boolean?
  champion_kills     Int?
  champion_first     Boolean?
  matches          matches  @relation(fields: [match_id], references: [match_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([match_id], map: "ix_team_objectives_match_id")
}

model match_timelines {
  match_id              String                       @id @db.VarChar(64)
  frame_interval        BigInt?
  end_of_game_result    String?                      @db.VarChar(64)
  raw_timeline_json     Json?
  matches               matches                      @relation(fields: [match_id], references: [match_id], onDelete: Cascade, onUpdate: NoAction)
  participant_frames    timeline_participant_frames[]
  timeline_events       timeline_events[]
}

model timeline_participant_frames {
  id                      Int             @id @default(autoincrement())
  match_id                String          @db.VarChar(64)
  frame_timestamp         Int
  participant_id          Int
  position_x             Int?
  position_y             Int?
  current_gold           Int?
  total_gold             Int?
  gold_per_second        Int?
  xp                     Int?
  level                  Int?
  minions_killed         Int?
  jungle_minions_killed  Int?
  match_timelines        match_timelines @relation(fields: [match_id], references: [match_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([match_id, frame_timestamp], map: "ix_tpf_match_ts")
  @@index([match_id, participant_id], map: "ix_tpf_match_participant")
}

model timeline_events {
  event_id         BigInt   @id @default(autoincrement())
  match_id         String   @db.VarChar(64)
  timestamp        BigInt?
  real_timestamp   BigInt?
  type             String?  @db.VarChar(64)
  raw_event_json   Json
  match_timelines  match_timelines @relation(fields: [match_id], references: [match_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([match_id, timestamp], map: "ix_timeline_events_match_ts")
  @@index([match_id, type], map: "ix_timeline_events_match_type")
}

model draft_actions {
  id           Int      @id @default(autoincrement())
  match_id     String   @db.VarChar(64)
  team_id      Int
  action_type  String   @db.VarChar(8)
  phase        String   @db.VarChar(8)
  champion_id  Int
  role         String?  @db.VarChar(32)
  turn         Int
  action_order Int?
  matches      matches  @relation(fields: [match_id], references: [match_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([match_id, phase, team_id, turn], map: "uq_draft_actions_match_phase_team_turn")
  @@index([match_id], map: "ix_draft_actions_match_id")
  @@index([champion_id], map: "ix_draft_actions_champion_id")
  @@index([match_id, team_id], map: "ix_draft_actions_match_team")
  @@index([action_type], map: "ix_draft_actions_action_type")
  @@index([role], map: "ix_draft_actions_role")
  @@index([match_id, phase], map: "ix_draft_actions_match_phase")
  @@index([match_id, team_id, phase], map: "ix_draft_actions_match_team_phase")
  @@index([match_id, phase, turn], map: "ix_draft_actions_match_phase_turn")
  @@index([match_id, action_order], map: "ix_draft_actions_match_order")
}

model participant_perks {
  id             Int      @id @default(autoincrement())
  match_id       String   @db.VarChar(64)
  player_id      Int
  // Primary rune path
  primary_style  Int?
  keystone       Int?
  primary_slot1  Int?
  primary_slot2  Int?
  primary_slot3  Int?
  // Secondary rune path
  sub_style      Int?
  sub_slot1      Int?
  sub_slot2      Int?
  // Stat shards
  stat_offense   Int?
  stat_flex      Int?
  stat_defense   Int?
  matches        matches  @relation(fields: [match_id], references: [match_id], onDelete: Cascade, onUpdate: NoAction)
  players        players  @relation(fields: [player_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([match_id, player_id], map: "uq_participant_perks_match_player")
  @@index([match_id], map: "ix_participant_perks_match_id")
  @@index([player_id], map: "ix_participant_perks_player_id")
  @@index([keystone], map: "ix_participant_perks_keystone")
  @@index([primary_style], map: "ix_participant_perks_primary_style")
}

